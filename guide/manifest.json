      "diagnostics/env_probe.py",
      "diagnostics/crash_parser.py",
      "diagnostics/regression_checker.py",
      "diagnostics/pre_submit_gate.py",
      "diagnostics/screenshot_memory_updater.py",
      "diagnostics/step_gate_engine.py",
      "diagnostics/reminder_checkpoint_validator.py"
    ],
    "validators": [
      "validators/syntax_validator.py",
