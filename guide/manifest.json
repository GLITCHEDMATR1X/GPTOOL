    "mechanic_acceptance_manifest_present",
    "screenshot_review_pass_when_visual",
    "screenshot_correction_plan_run_when_visual",
    "screenshot_memory_update_run_when_visual",
    "pre_submit_gate_pass_when_visual",
    "authoritative_build_receipt_pass",
    "scope_lock_receipt_pass",
    "candidate_workspace_receipt_pass",
    "runtime_validation_receipt_pass",
    "delivery_gate_receipt_pass"
